#!/bin/bash

# Installer script
# Downloads file from http://103.161.35.57/xui_installer.php
# Extracts it using tar -xzf
# Runs the extracted install script

# Set error handling
set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Create temporary directory
TEMP_DIR="/tmp/xui_installer_$$"
mkdir -p "$TEMP_DIR"
print_status "Created temporary directory: $TEMP_DIR"

# Change to temporary directory
cd "$TEMP_DIR"
print_status "Changed to directory: $TEMP_DIR"

# Download the file
DOWNLOAD_URL="http://basketball022.space/xui_installer_dev.php"
OUTPUT_FILE="xui_installer.tar.gz"
AUTH_HEADER="X-Installer-Key"
AUTH_KEY="wang-webhook-secret-key"

print_status "Downloading from $DOWNLOAD_URL..."
if command -v wget &> /dev/null; then
    wget --header="$AUTH_HEADER: $AUTH_KEY" -O "$OUTPUT_FILE" "$DOWNLOAD_URL"
elif command -v curl &> /dev/null; then
    curl -H "$AUTH_HEADER: $AUTH_KEY" -o "$OUTPUT_FILE" "$DOWNLOAD_URL"
else
    print_error "Neither wget nor curl is installed. Please install one of them."
    exit 1
fi

# Check if download was successful
if [ ! -f "$OUTPUT_FILE" ]; then
    print_error "Download failed or file not found"
    exit 1
fi

print_status "Download completed: $OUTPUT_FILE"

# Check if file is a valid tar.gz archive
if ! file "$OUTPUT_FILE" | grep -q "gzip compressed data"; then
    print_warning "File may not be a valid tar.gz archive"
fi

# Extract the tar.gz file
print_status "Extracting $OUTPUT_FILE..."
tar -xzf "$OUTPUT_FILE"

# Check if extraction was successful
if [ $? -ne 0 ]; then
    print_error "Extraction failed"
    exit 1
fi

print_status "Extraction completed"


# Build db.tar.gz and loadbalancer.tar.gz from main.tar.gz (same paths as xui_repo_worker).
if [ ! -f "main.tar.gz" ]; then
    print_error "main.tar.gz not found after extraction"
    exit 1
fi

LOADBALANCER_REMOVES=(
    'bin/install/*.tar.gz'
    'admin'
    'includes/cli/cache_handler.php'
    'includes/pages'
    'includes/js'
    'includes/lang'
    'includes/styles'
    'crons/backups.php'
    'crons/cache_engine.php'
    'crons/epg.php'
    'crons/plex.php'
    'crons/providers.php'
    'crons/root_mysql.php'
    'crons/series.php'
    'crons/tmdb.php'
    'crons/tmdb_popular.php'
    'www/streams/auth.php'
    'www/playlist.php'
    'reseller'
    'player'
    'ministra'
    'tools'
    'log.txt'
)

DB_REMOVES=(
    'bin/install/*.tar.gz'
    'admin'
    'includes/cli/cache_handler.php'
    'includes/pages'
    'includes/js'
    'includes/lang'
    'includes/styles'
    'crons/cache_engine.php'
    'www/streams'
    'www/api.php'
    'www/enigma2.php'
    'www/epg.php'
    'www/player_api.php'
    'www/playlist.php'
    'www/probe.php'
    'www/progress.php'
    'www/xplugin.php'
    'reseller'
    'player'
    'tools'
    'ministra'
    'log.txt'
)

build_variant_tarball() {
    local output_tgz="$1"
    shift
    local removes=("$@")
    local work path

    work=$(mktemp -d)
    tar -xzf "main.tar.gz" -C "$work"

    shopt -s nullglob
    for path in "${removes[@]}"; do
        if [[ "$path" == *'*'* ]]; then
            rm -f $work/$path 2>/dev/null || true
        else
            rm -rf "$work/$path"
        fi
    done
    shopt -u nullglob

    tar -czf "$output_tgz" -C "$work" .
    rm -rf "$work"
}

print_status "Building loadbalancer.tar.gz from main.tar.gz..."
build_variant_tarball "loadbalancer.tar.gz" "${LOADBALANCER_REMOVES[@]}"

print_status "Building db.tar.gz from main.tar.gz..."
build_variant_tarball "db.tar.gz" "${DB_REMOVES[@]}"

print_status "db.tar.gz and loadbalancer.tar.gz built from main.tar.gz"

# Find the extracted install script
# Look for common script names
INSTALL_SCRIPT=""
for script_name in install.sh setup.sh installer.sh install setup installer; do
    if [ -f "$script_name" ]; then
        INSTALL_SCRIPT="$script_name"
        break
    elif [ -f "./$script_name" ]; then
        INSTALL_SCRIPT="./$script_name"
        break
    fi
done

# If not found, look for any .sh file in current directory
if [ -z "$INSTALL_SCRIPT" ]; then
    INSTALL_SCRIPT=$(find . -maxdepth 1 -name "*.sh" -type f | head -n 1)
fi

# Check if install script was found
if [ -z "$INSTALL_SCRIPT" ]; then
    print_error "No install script found in the extracted files"
    print_status "Files in directory:"
    ls -la
    exit 1
fi

print_status "Found install script: $INSTALL_SCRIPT"

# Make sure the script is executable
chmod +x "$INSTALL_SCRIPT"
print_status "Made $INSTALL_SCRIPT executable"

# Run the install script
print_status "Running install script..."
echo "----------------------------------------"
python3 "$INSTALL_SCRIPT"
INSTALL_EXIT_CODE=$?
echo "----------------------------------------"

# Check if installation was successful
if [ $INSTALL_EXIT_CODE -eq 0 ]; then
    print_status "Installation completed successfully"
else
    print_error "Installation failed with exit code $INSTALL_EXIT_CODE"
    exit $INSTALL_EXIT_CODE
fi

# Optionally clean up temporary files
read -p "Do you want to delete temporary files? (y/n): " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    cd /
    rm -rf "$TEMP_DIR"
    print_status "Temporary files deleted"
else
    print_status "Temporary files kept at: $TEMP_DIR"
fi

print_status "Done!"